<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.new-top10.retrain</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>TOP10_RESOURCE_PROFILE</key>
        <string>host_full</string>
    </dict>
    
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PROJECT_DIR__/scripts/daily_retrain.sh</string>
        <string>monitor</string>
        <string>--trigger</string>
        <string>scheduled</string>
    </array>
    
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>2</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    
    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/logs/launchd_retrain.log</string>
    
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/logs/launchd_retrain.err</string>
    
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
